---
interface Subsystem {
  id: string;
  code: string;
  name: string;
  longDesc: string;
  techStack: string[];
  status: 'done' | 'working' | 'planned';
  icon: string;
  lead?: string;
}

const subsystems: Subsystem[] = [
  {
    id: "software",
    code: "SOF",
    name: "Flight Software",
    longDesc: "Developing RTOS-based flight firmware, Kalman filtering for state estimation, and telemetry transmission protocols.",
    techStack: ["C/C++", "FreeRTOS", "Python"],
    status: "working",
    icon: "▰",
    lead: "Šimon Balog"
  },
  {
    id: "hardware",
    code: "HAR",
    name: "Avionics & PCB",
    longDesc: "Designing custom multi-layer PCBs for flight computers, sensor boards, telemetry radios, and battery management systems.",
    techStack: ["KiCad", "STM32", "Altium"],
    status: "working",
    icon: "◈",
    lead: "Bedřich Březina"
  },
  {
    id: "structures",
    code: "STR",
    name: "Structures & Airframe",
    longDesc: "Engineering the rocket's body, fin geometry, and avionics bay — material selection, structural load analysis, and integrating internal subsystems into a flight-ready airframe.",
    techStack: ["CAD", "FEA", "Composites"],
    status: "planned",
    icon: "◇"
  },
  {
    id: "propulsion",
    code: "PRO",
    name: "Propulsion",
    longDesc: "Designing solid rocket motors, calculating fuel grain geometries, and testing on custom-made static test stands.",
    techStack: ["OpenMotor", "SolidWorks"],
    status: "planned",
    icon: "△"
  },
  {
    id: "simulation",
    code: "SIM",
    name: "Simulation & Aero",
    longDesc: "Simulating rocket trajectories, performing CFD aerodynamic simulations, and optimizing weight-to-thrust ratios.",
    techStack: ["OpenRocket", "ANSYS", "MATLAB"],
    status: "planned",
    icon: "◎"
  },
  {
    id: "recovery",
    code: "REC",
    name: "Recovery Systems",
    longDesc: "Designing servo-driven parachute deployment mechanisms, dual-deployment altimeter triggers, and shock cord sizing.",
    techStack: ["Dual Deploy", "Servo Trigger", "Altimeters"],
    status: "planned",
    icon: "□"
  }
];
---

<div class="subsystems-container">
  <div class="section-header">
    <span class="sub-tag font-mono">ORGANIZATION STRUCTURE</span>
    <h3 class="sub-title">Technical Subsystems</h3>
  </div>

  <div class="subsystems-grid">
    {subsystems.map((s) => (
      <div class={`subsystem-card subsystem-${s.status}`}>
        <div class={`card-glow-bar card-glow-${s.status}`}></div>
        <div class="card-top">
          <span class={`sub-icon sub-icon-${s.status} font-mono`}>{s.icon}</span>
          <span class={`status-pill status-${s.status} font-mono`}>{s.status.toUpperCase()}</span>
        </div>
        <div class="card-body">
          <span class="sub-code font-mono">[{s.code}]</span>
          <h4 class="sub-card-title">{s.name}</h4>
          <p class="sub-card-desc">{s.longDesc}</p>
        </div>
        <div class="tech-tags font-mono">
          {s.techStack.map((tech) => (
            <span class="tech-tag">{tech}</span>
          ))}
        </div>
        {s.lead && (
          <div class="sub-lead font-mono">
            <span class="lead-label">LEAD</span>
            <span class="lead-name">{s.lead}</span>
          </div>
        )}
      </div>
    ))}
  </div>
</div>

<style>
  .subsystems-container {
    margin-bottom: 2rem;
  }

  .section-header {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin-bottom: 1.5rem;
  }

  .sub-tag {
    font-size: 0.65rem;
    color: var(--accent-cyan);
    font-weight: 600;
    letter-spacing: 0.08em;
  }

  .sub-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: #ffffff;
  }

  .subsystems-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1rem;
  }

  .subsystem-card {
    padding: 1.25rem;
    background: rgba(11, 15, 25, 0.75);
    border: 1px solid rgba(59, 130, 246, 0.2);
    border-radius: 12px;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    position: relative;
    overflow: hidden;
    transition: border-color 0.3s ease, box-shadow 0.3s ease, transform 0.3s ease;
  }

  .subsystem-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
  }

  .subsystem-working:hover {
    border-color: rgba(249, 115, 22, 0.4);
    box-shadow: 0 8px 32px 0 rgba(249, 115, 22, 0.08);
  }

  .subsystem-done:hover {
    border-color: rgba(16, 185, 129, 0.4);
    box-shadow: 0 8px 32px 0 rgba(16, 185, 129, 0.08);
  }

  .subsystem-planned:hover {
    border-color: rgba(107, 114, 128, 0.3);
    box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.2);
  }

  .card-glow-bar {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
  }

  .card-glow-working {
    background: linear-gradient(to right, transparent, #f97316, #fbbf24, transparent);
  }

  .card-glow-done {
    background: linear-gradient(to right, transparent, #10b981, #34d399, transparent);
  }

  .card-glow-planned {
    background: linear-gradient(to right, transparent, rgba(107, 114, 128, 0.4), transparent);
  }

  .card-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .sub-icon {
    font-size: 1.1rem;
    line-height: 1;
  }

  .sub-icon-working {
    color: var(--accent-orange);
  }

  .sub-icon-done {
    color: var(--accent-emerald);
  }

  .sub-icon-planned {
    color: var(--color-text-muted);
  }

  .status-pill {
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    padding: 0.15rem 0.45rem;
    border-radius: 3px;
  }

  .status-working {
    background: rgba(249, 115, 22, 0.1);
    color: var(--accent-orange);
    border: 1px solid rgba(249, 115, 22, 0.2);
  }

  .status-done {
    background: rgba(16, 185, 129, 0.1);
    color: var(--accent-emerald);
    border: 1px solid rgba(16, 185, 129, 0.2);
  }

  .status-planned {
    background: rgba(107, 114, 128, 0.08);
    color: var(--color-text-muted);
    border: 1px solid rgba(107, 114, 128, 0.15);
  }

  .card-body {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .sub-code {
    font-size: 0.6rem;
    color: var(--color-text-muted);
    font-weight: 600;
    letter-spacing: 0.04em;
  }

  .sub-card-title {
    font-size: 1.05rem;
    font-weight: 600;
    color: #ffffff;
    margin: 0;
  }

  .sub-card-desc {
    font-size: 0.82rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
    margin: 0.2rem 0 0 0;
    flex-grow: 1;
  }

  .tech-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: 0.25rem;
  }

  .tech-tag {
    font-size: 0.6rem;
    background: rgba(6, 182, 212, 0.08);
    border: 1px solid rgba(6, 182, 212, 0.15);
    color: var(--accent-cyan);
    padding: 0.15rem 0.4rem;
    border-radius: 3px;
    letter-spacing: 0.02em;
  }

  .sub-lead {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding-top: 0.6rem;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    font-size: 0.65rem;
  }

  .lead-label {
    color: var(--color-text-muted);
    font-weight: 600;
    letter-spacing: 0.05em;
  }

  .lead-name {
    color: var(--color-text-secondary);
  }
</style>
