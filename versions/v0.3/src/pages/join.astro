---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Join Us | Mellotech">
  <main class="join-page">
    <div class="join-card glass-panel">
      <div class="join-glow-bar"></div>

      <div class="join-header">
        <span class="join-tag font-mono">RECRUITMENT</span>
        <h1 class="join-title">Join Us</h1>
        <p class="join-lead">
          Interested in electronics, programming or space?
        </p>
        <p class="join-cta">Fill in the form and we'll get back to you.</p>
      </div>

      <form id="join-form" class="join-form" onsubmit="return handleSubmit(event)">
        <div class="form-group">
          <label class="form-label font-mono" for="name">NAME</label>
          <input type="text" id="name" name="name" class="form-input" placeholder="Your name" required />
        </div>

        <div class="form-group">
          <label class="form-label font-mono" for="email">EMAIL</label>
          <input type="email" id="email" name="email" class="form-input" placeholder="your@email.com" required />
        </div>

        <div class="form-group">
          <label class="form-label font-mono" for="message">MESSAGE</label>
          <textarea id="message" name="message" class="form-input form-textarea" placeholder="Tell us about yourself — what interests you, what skills you have..." rows="4" required></textarea>
        </div>

        <button type="submit" class="form-submit font-mono">
          <span class="submit-text">SEND</span>
          <span class="submit-arrow">→</span>
        </button>
      </form>

      <div id="form-success" class="form-success" style="display:none">
        <span class="success-icon">✓</span>
        <p class="success-text">Thanks for reaching out!</p>
        <p class="success-hint font-mono">We'll get back to you as soon as possible.</p>
      </div>

      <div class="join-contact-info">
        <span class="contacts-label font-mono">OR CONTACT US DIRECTLY</span>

        <div class="contact-item">
          <span class="contact-role font-mono">MAIN LEADER</span>
          <span class="contact-name">Bedřich Březina</span>
          <a href="mailto:bedrich.brezina09@gmail.com" class="contact-email">bedrich.brezina09@gmail.com</a>
        </div>

        <div class="contact-item">
          <span class="contact-role font-mono">SOFTWARE</span>
          <span class="contact-name">Šimon Balog</span>
          <a href="mailto:simonbalog11@seznam.cz" class="contact-email">simonbalog11@seznam.cz</a>
        </div>
      </div>

      <div class="join-footer font-mono">
        Also find us on Discord: NTPgKwrTaH
      </div>
    </div>
  </main>
</Layout>

<script>
  function handleSubmit(event) {
    event.preventDefault();
    const name = document.getElementById('name').value;
    const email = document.getElementById('email').value;
    const message = document.getElementById('message').value;

    const subject = encodeURIComponent('New Mellotech Member Interest');
    const body = encodeURIComponent(
      `Name: ${name}\nEmail: ${email}\n\nMessage:\n${message}`
    );

    document.getElementById('join-form').style.display = 'none';
    document.getElementById('form-success').style.display = 'flex';

    window.location.href = `mailto:bedrich.brezina09@gmail.com;simonbalog11@seznam.cz?subject=${subject}&body=${body}`;
    return false;
  }
</script>

<style>
  .join-page {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: calc(100vh - 4rem);
    padding: 2rem 0;
  }

  .join-card {
    max-width: 520px;
    width: 100%;
    padding: 2.5rem;
    background: rgba(8, 12, 24, 0.85);
    border-color: rgba(6, 182, 212, 0.2);
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .join-card:hover {
    border-color: rgba(6, 182, 212, 0.4);
    box-shadow: 0 8px 32px rgba(6, 182, 212, 0.1);
  }

  .join-glow-bar {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(to right, transparent, #06b6d4, #8b5cf6, transparent);
  }

  .join-header {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .join-tag {
    font-size: 0.65rem;
    color: var(--accent-cyan);
    font-weight: 600;
    letter-spacing: 0.08em;
  }

  .join-title {
    font-size: 2rem;
    font-weight: 700;
    color: #ffffff;
    text-shadow: 0 0 10px rgba(6, 182, 212, 0.5);
  }

  .join-lead {
    font-size: 1.1rem;
    color: var(--color-text-primary);
    margin-top: 0.5rem;
  }

  .join-cta {
    font-size: 0.95rem;
    color: var(--accent-cyan);
    font-weight: 600;
  }

  .join-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .form-label {
    font-size: 0.65rem;
    color: var(--accent-cyan);
    font-weight: 600;
    letter-spacing: 0.08em;
  }

  .form-input {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.9rem;
    padding: 0.7rem 0.85rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 6px;
    color: #ffffff;
    outline: none;
    transition: border-color 0.2s ease;
  }

  .form-input::placeholder {
    color: var(--color-text-muted);
  }

  .form-input:focus {
    border-color: var(--accent-cyan);
    box-shadow: 0 0 10px rgba(6, 182, 212, 0.1);
  }

  .form-textarea {
    resize: vertical;
    min-height: 100px;
    line-height: 1.5;
  }

  .form-submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.8rem 1.5rem;
    background: rgba(6, 182, 212, 0.1);
    border: 1px solid rgba(6, 182, 212, 0.3);
    border-radius: 6px;
    color: var(--accent-cyan);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .form-submit:hover {
    background: rgba(6, 182, 212, 0.2);
    border-color: var(--accent-cyan);
    box-shadow: 0 0 15px rgba(6, 182, 212, 0.15);
  }

  .submit-arrow {
    transition: transform 0.2s ease;
  }

  .form-submit:hover .submit-arrow {
    transform: translateX(4px);
  }

  .form-success {
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    padding: 1.5rem;
    background: rgba(16, 185, 129, 0.08);
    border: 1px solid rgba(16, 185, 129, 0.25);
    border-radius: 8px;
    text-align: center;
  }

  .success-icon {
    font-size: 2rem;
    color: var(--accent-emerald);
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(16, 185, 129, 0.1);
    border-radius: 50%;
  }

  .success-text {
    font-size: 1.1rem;
    color: #ffffff;
    font-weight: 600;
  }

  .success-hint {
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .join-contact-info {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .contacts-label {
    font-size: 0.65rem;
    color: var(--accent-cyan);
    font-weight: 600;
    letter-spacing: 0.08em;
  }

  .contact-item {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 0.85rem;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 6px;
  }

  .contact-item:hover {
    border-color: rgba(6, 182, 212, 0.2);
  }

  .contact-role {
    font-size: 0.6rem;
    color: var(--accent-cyan);
    font-weight: 600;
    letter-spacing: 0.05em;
  }

  .contact-name {
    font-size: 0.95rem;
    color: #ffffff;
    font-weight: 600;
  }

  .contact-email {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .contact-email:hover {
    color: var(--accent-cyan);
  }

  .join-footer {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-align: center;
    padding-top: 0.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .font-mono {
    font-family: 'Space Grotesk', monospace;
  }
</style>
